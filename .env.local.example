# Copiá este archivo a  .env.local  y completá con tus datos reales.
# (No subas .env.local a git — ya está en .gitignore.)

# Poné en 1 para que la app use la BASE DE DATOS real (API).
# Si lo dejás vacío/0, la app funciona con datos de prueba en memoria.
NEXT_PUBLIC_USE_API=1

# ---- SQL Server (Azure) ----
SQL_SERVER=mysqladelante.database.windows.net
SQL_DATABASE=AdelanteSBX
SQL_USER=tu_usuario
SQL_PASSWORD=tu_password
# Alternativa: una sola cadena (si la usás, ignora las 4 de arriba)
# SQL_CONNECTION_STRING=Server=tcp:mysqladelante.database.windows.net,1433;Database=AdelanteSBX;User Id=...;Password=...;Encrypt=true;

# ---- Business Central (para los selectores y empujar documentos) ----
# BC_TENANT_ID=
# BC_CLIENT_ID=
# BC_CLIENT_SECRET=
# BC_ENVIRONMENT=Sandbox
# BC_COMPANY=ADELANTE_DESARROLLOS_NUEVA
